---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    tags?: string[];

    cover?: {
      src: string;
    };
  };
}
const { frontmatter } = Astro.props;
const isRTL = frontmatter.lang === "fa";


const ogImage = frontmatter.cover
  ? new URL(frontmatter.cover.src, Astro.site).href
  : undefined;


const pubDate = new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<Layout title={frontmatter.title} description={frontmatter.description} ogImage={ogImage}  lang={frontmatter.lang ?? "en"} dir={isRTL ? "rtl" : "ltr"}>
  <article class="post">
    <div class="container">
      <header class="post-header">
        <h1>{frontmatter.title}</h1>
        <p class="post-meta">
          <span class="date">{pubDate}</span>
          {frontmatter.tags && frontmatter.tags.length > 0 && (
            <span class="tags">
              {frontmatter.tags.map((tag) => (
                <span class="tag">#{tag}</span>
              ))}
            </span>
          )}
        </p>
        <p class="post-description">{frontmatter.description}</p>
      </header>

      <div class="post-content">
        <slot />
      </div>

      <footer class="post-footer">
        <hr />
        <nav class="post-nav">
          <a href={import.meta.env.BASE_URL} class="back-link">← back to posts</a>
        </nav>
      </footer>
    </div>
  </article>
</Layout>

<style>
  .post {
    padding: 2rem 0;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--color-surface-light);
    direction: ltr;
    text-align: left;
  }

  .post-meta {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    color: var(--color-text-dim);
    font-size: 0.95rem;
    flex-wrap: wrap;
  }

  .tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    color: var(--color-accent-warm);
    background-color: var(--color-surface);
    padding: 0.25rem 0.75rem;
    border-radius: 2px;
    font-size: 0.85rem;
    border: 1px solid var(--color-surface-light);
  }

  .post-description {
    font-size: 1.15rem;
    color: var(--color-text-dim);
    margin-top: 1rem;
    font-style: italic;
  }

  .post-content {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .post-content :global(img) {
    display: block;
    max-width: 800px;
    width: auto;
    max-height: 600px;
    height: auto;
    border-radius: 2px;
    margin: 1.5rem auto;
    border: 1px solid var(--color-surface-light);
  }

  .post-content :global(a) {
    direction: ltr;
    unicode-bidi: bidi-override;
    text-align: left;
    display: inline-block;
    max-width: 100%;
    word-break: break-all;
  }

  /* If a blockquote contains an LTR link, make the blockquote align nicely */
  .post-content :global(blockquote) {
    direction: ltr;
    text-align: left;
  }

  .post-footer {
    margin-top: 3rem;
  }

  .back-link {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-primary);
    border-radius: 2px;
    transition: all 0.2s ease;
  }

  .back-link:hover {
    background-color: var(--color-surface);
    text-shadow: var(--glow-primary);
  }

  @media (max-width: 640px) {
    .post {
      padding: 1rem 0;
    }

    .post-header {
      margin-bottom: 2rem;
    }

    .post-content {
      font-size: 1rem;
    }
  }
</style>
