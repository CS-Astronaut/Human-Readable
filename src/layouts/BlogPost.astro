---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    tags?: string[];

    cover?: {
      src: string;
    };
  };
}
const { frontmatter } = Astro.props;
const isRTL = frontmatter.lang === "fa";


const ogImage = frontmatter.cover
  ? new URL(frontmatter.cover.src, Astro.site).href
  : undefined;


const pubDate = new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<Layout title={frontmatter.title} description={frontmatter.description} ogImage={ogImage}  lang={frontmatter.lang ?? "en"} dir={isRTL ? "rtl" : "ltr"}>
  <article class="post">
    <div class="container">
      <header class="post-header">
        <div class="header-title-container">
          <h1>{frontmatter.title}</h1>
          <button id="copy-link-btn" class="copy-btn" title="Copy post link" aria-label="Copy post link">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="copy-icon">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
            <span class="copy-feedback">copied!</span>
          </button>
        </div>
        <p class="post-meta">
          <span class="date">{pubDate}</span>
          {frontmatter.tags && frontmatter.tags.length > 0 && (
            <span class="tags">
              {frontmatter.tags.map((tag) => (
                <span class="tag">#{tag}</span>
              ))}
            </span>
          )}
        </p>
        <p class="post-description">{frontmatter.description}</p>
      </header>

      <div class="post-content">
        <slot />
      </div>

      <footer class="post-footer">
        <hr />
        <nav class="post-nav">
          <a href={import.meta.env.BASE_URL} class="back-link">← back to posts</a>
        </nav>
      </footer>
    </div>
  </article>
</Layout>

<script>
  const copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyBtn.classList.add('copied');
        setTimeout(() => {
          copyBtn.classList.remove('copied');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy post link: ', err);
      }
    });
  }
</script>

<style>
  .post {
    padding: 2rem 0;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--color-surface-light);
    direction: ltr;
    text-align: left;
  }

  .header-title-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
  }

  .header-title-container h1 {
    margin: 0;
    flex: 1;
  }

  .copy-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface);
    border: 1px solid var(--color-surface-light);
    color: var(--color-primary);
    padding: 0.5rem;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.25s ease;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-primary);
    box-shadow: var(--glow-primary);
    background-color: rgba(122, 162, 247, 0.05);
  }

  .copy-icon {
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .copy-btn:active .copy-icon {
    transform: scale(0.85);
  }

  .copy-feedback {
    position: absolute;
    bottom: 120%;
    left: 50%;
    transform: translateX(-50%) translateY(5px);
    background-color: var(--color-success);
    color: var(--color-bg);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    font-size: 0.75rem;
    font-family: "Courier New", monospace;
    font-weight: bold;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(158, 206, 106, 0.3);
  }

  .copy-btn.copied .copy-feedback {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .post-meta {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    color: var(--color-text-dim);
    font-size: 0.95rem;
    flex-wrap: wrap;
  }

  .tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    color: var(--color-accent-warm);
    background-color: var(--color-surface);
    padding: 0.25rem 0.75rem;
    border-radius: 2px;
    font-size: 0.85rem;
    border: 1px solid var(--color-surface-light);
  }

  .post-description {
    font-size: 1.15rem;
    color: var(--color-text-dim);
    margin-top: 1rem;
    font-style: italic;
  }

  .post-content {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .post-content :global(img) {
    display: block;
    max-width: 100%;
    width: auto;
    max-height: 600px;
    height: auto;
    border-radius: 2px;
    margin: 1.5rem auto;
    border: 1px solid var(--color-surface-light);
  }

  .post-content :global(a) {
    direction: ltr;
    unicode-bidi: bidi-override;
    text-align: left;
    display: inline-block;
    max-width: 100%;
    word-break: break-all;
  }

  /* If a blockquote contains an LTR link, make the blockquote align nicely */
  .post-content :global(blockquote) {
    direction: ltr;
    text-align: left;
  }

  .post-footer {
    margin-top: 3rem;
  }

  .back-link {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-primary);
    border-radius: 2px;
    transition: all 0.2s ease;
  }

  .back-link:hover {
    background-color: var(--color-surface);
    text-shadow: var(--glow-primary);
  }

  @media (max-width: 640px) {
    .post {
      padding: 1rem 0;
    }

    .post-header {
      margin-bottom: 2rem;
    }

    .post-content {
      font-size: 1rem;
    }
  }
</style>

