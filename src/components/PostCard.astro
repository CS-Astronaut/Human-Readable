---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const slug = post.slug;

const pubDateFormatted = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class={`post-card ${featured ? 'featured' : ''}`}>
  <div class="card-content">
    <h3 class="card-title">
      <a href={`{import.meta.env.BASE_URL}blog/${slug}`}>{title}</a>
    </h3>
    <p class="card-description">{description}</p>
    <div class="card-footer">
      <span class="card-date">{pubDateFormatted}</span>
      {tags && tags.length > 0 && (
        <div class="card-tags">
          {tags.map((tag) => (
            <span class="card-tag">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</article>

<style>
  .post-card {
    padding: 1.5rem;
    border: 1px solid var(--color-surface-light);
    border-radius: 2px;
    background-color: var(--color-surface);
    transition: all 0.25s ease;
    margin-bottom: 1.5rem;
  }

  .post-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--glow-primary);
  }

  .post-card.featured {
    border: 2px solid var(--color-accent);
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-surface-light) 100%);
    padding: 2rem;
    margin-bottom: 3rem;
  }

  .post-card.featured .card-title {
    color: var(--color-accent);
    text-shadow: var(--glow-accent);
  }

  .card-title {
    margin-bottom: 0.75rem;
    margin-top: 0;
  }

  .card-title a {
    color: var(--color-primary);
    border: none;
    transition: color 0.2s ease;
  }

  .card-title a:hover {
    color: var(--color-accent);
  }

  .featured .card-title a {
    color: var(--color-accent);
  }

  .card-description {
    color: var(--color-text-dim);
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
  }

  .card-date {
    color: var(--color-text-dim);
  }

  .card-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .card-tag {
    color: var(--color-accent-warm);
    background-color: rgba(122, 162, 247, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
    border: 1px solid var(--color-accent-warm);
  }

  @media (max-width: 640px) {
    .post-card {
      padding: 1rem;
    }

    .post-card.featured {
      padding: 1.5rem;
    }

    .card-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
